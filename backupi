choose_restore_source() {
  local choices=()
  local choice snapshot

  validate_backup_root
  choices+=("$CURRENT_ROOT")
  if [[ -d "$SNAPSHOT_PARENT" ]]; then
    while IFS= read -r snapshot; do
      choices+=("$snapshot")
    done < <(find "$SNAPSHOT_PARENT" -mindepth 1 -maxdepth 1 -type d ! -name '.tmp-*' -printf '%p\n' 2>/dev/null | sort -r)
  fi

  while true; do
    printf '\nRestore source\n'
    local i=1
    for snapshot in "${choices[@]}"; do
      if [[ "$snapshot" == "$CURRENT_ROOT" ]]; then
        printf '%2d) current - %s\n' "$i" "$snapshot"
      else
        printf '%2d) snapshot - %s\n' "$i" "$(basename "$snapshot")"
      fi
      ((i++))
    done
    printf ' b) Back\n'
    printf 'Choose restore source: '
    read -r choice
    [[ "$choice" == "b" ]] && return 0
    [[ "$choice" =~ ^[0-9]+$ ]] || continue
    (( choice >= 1 && choice <= ${#choices[@]} )) || continue
    RESTORE_SOURCE_ROOT="${choices[$((choice - 1))]}"
    info "Restore source set to: $RESTORE_SOURCE_ROOT"
    return 0
  done
}

restore_menu() {
  while true; do
    cat <<EOF

Restore menu
Restore source: $(display_value "$RESTORE_SOURCE_ROOT")

1) Restore backupi configuration
2) Restore recommended safe user entries
3) Restore packages and Flatpaks
4) Choose one safe entry
5) Choose one risky entry
6) Choose restore source
7) Restore all safe entries, including safe /etc entries
8) Back
EOF
    printf 'Choose option: '
    read -r choice
    case "$choice" in
      1) restore_backupi_config ; pause ;;
      2) restore_matching safe user-safe 0 "Recommended safe user restore" ; pause ;;
      3) restore_packages ; pause ;;
      4) choose_single_restore safe ;;
      5) choose_single_restore risky ;;
      6) choose_restore_source ; pause ;;
