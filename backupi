      1) run_backup_all ; pause ;;
      2) run_backup_detected ; pause ;;
      3) restore_menu ;;
      4) print_system_info ; pause ;;
      5) list_items ; pause ;;
      6) config_menu ;;
      7) print_credits ; pause ;;
      8|q|Q) exit 0 ;;
    esac
  done
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --backup) COMMAND="backup"; shift ;;
    --backup-detected) COMMAND="backup-detected"; shift ;;
    --check-updates) COMMAND="check-updates"; shift ;;
    --system-info) COMMAND="system-info"; shift ;;
    --restore-safe) COMMAND="restore-safe"; shift ;;
    --restore-packages) COMMAND="restore-packages"; shift ;;
    --restore-backupi-config) COMMAND="restore-backupi-config"; shift ;;
    --list) COMMAND="list"; shift ;;
    --edit-config) COMMAND="edit-config"; shift ;;
    --set-backup-root)
      [[ $# -ge 2 ]] || die "--set-backup-root needs a directory"
      COMMAND="set-backup-root"
      NEW_BACKUP_ROOT="$2"
      shift 2
      ;;
    --set-snapshot-retention)
      [[ $# -ge 2 ]] || die "--set-snapshot-retention needs a number"
      COMMAND="set-snapshot-retention"
      NEW_SNAPSHOT_RETENTION="$2"
      shift 2
      ;;
    --config)
      [[ $# -ge 2 ]] || die "--config needs a file"
      CONFIG_FILE="$2"
      shift 2
      ;;
    --dry-run) DRY_RUN=1; shift ;;
    --version) print_credits; exit 0 ;;
    --credits) print_credits; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown argument: $1" ;;
  esac
done

setup_colors
load_config
load_update_config

case "$COMMAND" in
  backup) run_backup_all ;;
  backup-detected) run_backup_detected ;;
  check-updates) check_updates manual ;;
  system-info) print_system_info ;;
  restore-safe) restore_matching safe user-safe 0 "Recommended safe user restore" ;;
  restore-packages) restore_packages ;;
  restore-backupi-config) restore_backupi_config ;;
  list) list_items ;;
  edit-config) edit_config ;;
  set-backup-root) set_backup_root "$NEW_BACKUP_ROOT" ;;
  set-snapshot-retention) set_snapshot_retention "$NEW_SNAPSHOT_RETENTION" ;;
  menu) maybe_check_updates_on_start ; setup_menu ; main_menu ;;
esac
